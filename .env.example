# Copy this file to .env and fill in the key for whichever provider you use.
# You only need ONE of the two keys.

# Which provider to use: "gemini" or "openai"
PROVIDER=gemini

# Google AI Studio key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenAI platform key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Optional model overrides. Defaults shown.
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4.1-mini
